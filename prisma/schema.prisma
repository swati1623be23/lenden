generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String @id @default(cuid())
  name             String
  email            String @unique
  password         String
  profilePhotoUrl  String?
  shopName         String?
  shopPhone        String?
  shopAddress      String?
  shopLogoUrl      String?
  notifications    Notification[]
}

model Customer {
  id       String    @id @default(cuid())
  name     String
  phone    String?
  address  String?
  credits  Credit[]
  payments Payment[]
}

model Credit {
  id         String   @id @default(cuid())
  amount     Float
  note       String?
  createdAt  DateTime @default(now())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
}

model Payment {
  id         String   @id @default(cuid())
  amount     Float
  createdAt  DateTime @default(now())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
}

model Notification {
  id                String   @id @default(cuid())
  userId            String
  type              String   // customer_added, credit_added, payment_added, overdue_reminder, import_event, export_event
  title             String
  message           String
  relatedCustomerId String?
  isRead            Boolean  @default(false)
  createdAt         DateTime @default(now())
  
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
